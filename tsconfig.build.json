{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "incremental": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": true
  },
  "include": ["./src/**/*"],
  "exclude": ["./node_modules", "./dist", "./**/*.test.ts", "./**/*.test.tsx"]
}
