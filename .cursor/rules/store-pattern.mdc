## Store Configuration

### Creating a Store Hook

Always create a custom hook for each store to ensure consistent configuration:

```typescript
// src/app/(secure)/module/feature/hooks/use-store.ts
import type { Entity } from '@/lib/common/ds/types/module/Entity';
import { useStore } from 'venky-core/client';

export function useEntityStore() {
  return useStore<Entity>({
    datasourceId: 'Entity',
    page: 'entity-page',
    alias: 'entity-list',
    limit: 20,
    includeCount: true,
    autoQuery: true,
    sort: { createdAt: -1, secondColumn: -2 },
  });
}
```

### Configuration by Use Case

#### List Page Store
```typescript
export function useEntityListStore() {
  return useStore<Entity>({
    datasourceId: 'Entity',
    page: 'entity-page',
    alias: 'entity-list',
    limit: 20,              // Standard page size
    includeCount: true,     // Enable pagination
    autoQuery: true,        // Auto-fetch on mount
    autoRefresh: true,      // Real-time updates (optional)
    sort: { createdAt: -1 },
  });
}
```

#### Detail/Edit Page Store
```typescript
export function useEntityEditStore() {
  return useStore<Entity>({
    datasourceId: 'Entity',
    page: 'entity-detail-page',
    alias: 'entity-edit',
    limit: 1,               // Single record
    autoQuery: false,       // Manual query with ID
  });
}
```

#### Dialog Form Store
```typescript
export function useEntityDialogStore() {
  return useStore<Entity>({
    datasourceId: 'Entity',
    page: 'entity-page',
    alias: 'entity-dialog',  // Separate alias from list
    limit: 1,
    autoQuery: false,
  });
}
```

#### ComboboxInput Store (Lookup Data)
```typescript
export function useUserLookupStore() {
  return useStore<Users>({
    datasourceId: 'Users',
    page: 'user-lookup',
    alias: 'user-combobox',
    limit: 50,
    autoQuery: false,
    select: ['userName', 'displayName', 'email'],  // Only needed fields
  });
}
```

> **Full Pattern**: For complete Select/ComboboxInput pattern including options hooks, SmartSearch Select columns, and form integration, see `venky-ui-patterns` and `venky-data-patterns` skills.

#### Real-Time Updates Store
```typescript
export function useNotificationsStore() {
  return useStore<Notifications>({
    datasourceId: 'Notifications',
    page: 'notifications-page',
    alias: 'notifications-list',
    limit: 20,
    autoQuery: true,
    autoRefresh: true,  // Subscribe to SSE for real-time updates
  });
}
```

### Store Props Reference

| Prop | Type | Default | Description |
|------|------|---------|-------------|
| `datasourceId` | `string` | Required | DataSource name |
| `page` | `string` | Required | Page identifier for store key |
| `alias` | `string` | Required | Instance identifier for store key |
| `limit` | `number` | `20` | Page size for queries |
| `autoQuery` | `boolean` | `false` | Auto-fetch on mount |
| `autoRefresh` | `boolean` | `false` | Real-time updates via SSE |
| `includeCount` | `boolean` | `false` | Include total count for pagination |
| `filterLocally` | `boolean` | `false` | Client-side filtering (when full dataset is loaded) |
| `select` | `string[]` | `undefined` | Field projection (for performance) |
| `match` | `object` | `undefined` | Default equality filters (merged with executeQuery) |
| `filters` | `Filter[]` | `undefined` | Default complex filters with operators (merged with executeQuery) |
| `sort` | `object` | `undefined` | Default sort order (see Sort Priority below) |
| `invalidateOnSave` | `string[]` | `undefined` | Query action names to invalidate on save |
| `invalidateStoresOnSave` | `StoreIdentifier[]` | `undefined` | Other stores to refresh on save |

### Default Filters (match and filters)

Use `match` for simple equality filtering and `filters` for complex conditions with operators.

#### Simple Equality with `match`

```typescript
// Filter projects where isArchived = false
export function useActiveProjectsStore() {
  return useStore<WKProjects>({
    datasourceId: 'WKProjects',
    page: 'project-switcher',
    alias: 'active-projects',
    limit: 500,
    autoQuery: true,
    match: { isArchived: false },  // Simple equality
    sort: { projectName: 1 },
  });
}
```

#### Complex Conditions with `filters`

```typescript
// Filter periods with complex conditions
export function useRecentPeriodsStore() {
  return useStore<WKTimesheetPeriods>({
    datasourceId: 'WKTimesheetPeriods',
    page: 'period-selector',
    alias: 'recent-periods',
    limit: 500,
    autoQuery: true,
    filters: [
      { periodEnd: { inthepast: new Date().toISOString() } },
      { periodYear: { gte: new Date().getFullYear() - 1 } },
    ],
    sort: { periodYear: 1, periodNumber: 2 },
  });
}
```

#### Combining match and filters

```typescript
// Both can be used together
export function useActiveTasksStore() {
  return useStore<WKTasks>({
    datasourceId: 'WKTasks',
    page: 'task-list',
    alias: 'active-tasks',
    autoQuery: true,
    match: { projectId: 'abc123' },  // Simple equality
    filters: [{ status: { in: ['Active', 'In_Progress'] } }],  // Complex operator
  });
}
```

**Note:** `match` and `filters` are merged with any conditions passed to `executeQuery()`. Use these for static filters that don't change during the component lifecycle. For dynamic filters that depend on state/props, use `usePreQuery` or `executeQuery()` instead.

### Sort Priority

Sort values use a **signed priority system**:
- **Sign** determines direction: positive = ascending, negative = descending
- **Absolute value** determines priority: `1` = primary sort, `2` = secondary sort, etc.

```typescript
sort: {
  createdAt: -1,    // Primary sort: descending (newest first)
  name: 2,          // Secondary sort: ascending (A-Z)
  status: -3,       // Tertiary sort: descending
}
```

| Value | Direction | Priority |
|-------|-----------|----------|
| `1` | Ascending | Primary |
| `-1` | Descending | Primary |
| `2` | Ascending | Secondary |
| `-2` | Descending | Secondary |
| `3` | Ascending | Tertiary |
| `-3` | Descending | Tertiary |

