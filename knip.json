{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/venky-exports/**/*.ts"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "**/node_modules/**",
    "**/.next/**",
    "**/public/**",
    "**/migrations/**",
    "**/db-scripts/**",
    "**/email-templates/**",
    "**/src/components/ui/**",
    "**/src/3rd-party/**",
    "**/test-results/**",
    "**/playwright-report/**",
    "**/hf_cache/**",
    "**/python-service/**",
    "**/rag_docs/**",
    "**/docker/**",
    "**/aws/**",
    "**/config/**",
    "**/e2e/**",
    "**/*.css",
    "**/*.sql",
    "**/*.html",
    "**/*.png",
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.svg",
    "**/*.ico",
    "**/*.otf",
    "**/*.txt",
    "**/*.yml",
    "**/*.yaml",
    "**/*.sh",
    "**/tsconfig*.json",
    "**/next-env.d.ts",
    "**/components.json",
    "**/biome.jsonc",
    "**/.lintstagedrc",
    "**/pnpm-lock.yaml",
    "**/pnpm-workspace.yaml",
    "**/Dockerfile*",
    "**/README.md",
    "**/AGENTS.md",
    "**/page-pattern.rule",
    "**/env.example.txt"
  ],
  "ignoreDependencies": ["@types/*", "@vitest/coverage-v8", "tsx", "tailwind-scrollbar", "diff-match-patch"],
  "ignoreBinaries": []
}
