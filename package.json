{
  "name": "venky-core",
  "version": "1.0.0",
  "description": "Venky Core - Shared components, utilities, and types for Venky applications",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/uv-venky/venky-core.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24.13.0"
  },
  "main": "./dist/venky-exports/core/ui/index.js",
  "types": "./dist/venky-exports/core/ui/index.d.ts",
  "bin": {
    "venky-codegen-action-params": "./dist/venky-exports/core/codegen/bin.js"
  },
  "scripts": {
    "build": "rimraf dist && cross-env NODE_OPTIONS='--max-old-space-size=8192' tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/copy-static.mjs",
    "build:watch": "pnpm build && cross-env NODE_OPTIONS='--max-old-space-size=8192' tsc -p tsconfig.build.json --watch --preserveWatchOutput & tsc-alias -p tsconfig.build.json --watch",
    "check:unused": "knip",
    "check:server-routes-boundary": "node scripts/check-server-routes-boundary.mjs",
    "check:node-security": "node scripts/check-node-security.js",
    "clean": "rimraf .next",
    "format": "biome format --write",
    "build:next": "next build",
    "debug": "next dev --inspect",
    "dev": "next dev",
    "format:check": "biome format",
    "lint": "biome lint .",
    "lint:all": "pnpm lint && pnpm lint:react-hooks",
    "lint:fix": "biome lint --write --unsafe",
    "lint:react-hooks": "eslint src --ext .ts,.tsx",
    "ncu": "ncu",
    "ncu:overrides": "node scripts/update-overrides.js",
    "ncu:overrides:update": "node scripts/update-overrides.js --update",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "start": "next start",
    "sync-deps": "node scripts/sync-deps.js",
    "sync-deps:fix": "node scripts/sync-deps.js --sync",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test visual-regression",
    "test:visual:report": "playwright show-report",
    "test:visual:update": "playwright test visual-regression --update-snapshots && pnpm format",
    "check:data-ui-client-boundary": "node scripts/check-data-ui-client-boundary.mjs",
    "typecheck": "tsgo --noEmit",
    "codegen:action-params": "tsx scripts/codegen-action-param-schemas.ts",
    "codegen:action-params:check": "tsx scripts/codegen-action-param-schemas.ts && git diff --exit-code -- src/lib/server/actions/param-schemas.generated.ts",
    "migrate": "tsx scripts/migrate run",
    "migrate:add": "tsx scripts/migrate add",
    "go": "node scripts/publish-go.mjs"
  },
